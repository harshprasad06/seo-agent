# ============================================================
# SEO Agent — Environment Variables (Testing / Free-Tier Stack)
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── Google OAuth (GSC + GA + Sign-in) ───────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google Gemini (primary LLM — free tier) ─────────────────
# aistudio.google.com → Get API key
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY=your_gemini_api_key

# ── Groq (fallback LLM — free tier) ─────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key

# ── Serper.dev (SERP / keyword data — 2,500 free searches/mo) ─
# serper.dev → Dashboard → API Key
SERPER_API_KEY=your_serper_api_key

# ── Moz API (backlink data) ──────────────────────────────────
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# ── Supabase / Postgres ──────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://user:password@localhost:5432/seo_agent

# ── Google PageSpeed Insights ────────────────────────────────
GOOGLE_PSI_API_KEY=your_pagespeed_api_key
PAGESPEED_API_KEY=your_pagespeed_api_key

# ── Google Analytics 4 ──────────────────────────────────────
GA4_PROPERTY_ID=

# ── Site configuration ───────────────────────────────────────
SITE_URL=https://yoursite.com/
SITE_NAME=YourSiteName
SITE_DESCRIPTION=A brief description of what your site does
SITE_BRANDED_TERMS=yourbrand,your brand name
SITE_SEED_KEYWORDS=your main keyword,second keyword,third keyword

# ── GitHub (for blog post PRs) ───────────────────────────────
GITHUB_PAT=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repo_name
GITHUB_DEFAULT_BRANCH=main

# ── NextAuth ─────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ── Hugging Face (AI image generation for blog posts) ────────────────────────
# huggingface.co/settings/tokens → New token (Read access, free)
HUGGINGFACE_API_KEY=your_huggingface_token
